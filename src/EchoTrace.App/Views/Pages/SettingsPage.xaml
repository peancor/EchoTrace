<Page x:Class="EchoTrace.App.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Settings">
    <StackPanel Margin="24">
        <TextBlock Text="Settings" FontSize="32" FontWeight="SemiBold" />
        <TextBlock Text="General EchoTrace preferences" Margin="0,4,0,24" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Application theme" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="{Binding ThemeDescription}" Margin="0,4,18,0" TextWrapping="Wrap" />
            </StackPanel>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding ThemeOptions}"
                      SelectedItem="{Binding SelectedTheme}"
                      VerticalAlignment="Center" />
        </Grid>
    </StackPanel>
</Page>
